<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VSMS.VolunteerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:VSMS.VolunteerApp.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Login (no tabs visible) -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.TabBarIsVisible="False" />

    <!-- Register (no tabs visible) -->
    <ShellContent
        Title="Register"
        ContentTemplate="{DataTemplate views:RegisterPage}"
        Route="RegisterPage"
        Shell.TabBarIsVisible="False" />

    <!-- Main App with Bottom Tab Bar -->
    <TabBar Route="MainTabs">
        <Tab Title="Dashboard" Route="DashboardTab">
            <ShellContent
                ContentTemplate="{DataTemplate views:DashboardPage}"
                Route="DashboardPage" />
        </Tab>

        <Tab Title="Opportunities" Route="OpportunitiesTab">
            <ShellContent
                ContentTemplate="{DataTemplate views:OpportunitiesPage}"
                Route="OpportunitiesPage" />
        </Tab>

        <Tab Title="Profile" Route="ProfileTab">
            <ShellContent
                ContentTemplate="{DataTemplate views:ProfilePage}"
                Route="ProfilePage" />
        </Tab>
    </TabBar>

</Shell>

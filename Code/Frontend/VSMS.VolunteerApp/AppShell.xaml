<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="VSMS.VolunteerApp.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:VSMS.VolunteerApp.Views"
    Shell.FlyoutBehavior="Disabled">

    <!-- Login (no tabs visible) -->
    <ShellContent
        Title="Login"
        ContentTemplate="{DataTemplate views:LoginPage}"
        Route="LoginPage"
        Shell.TabBarIsVisible="False" />

    <!-- Main App with Bottom Tab Bar -->
    <TabBar Route="MainTabs">
        <ShellContent
            Title="Dashboard"
            Icon="tab_dashboard.svg"
            ContentTemplate="{DataTemplate views:DashboardPage}"
            Route="DashboardPage" />

        <ShellContent
            Title="Opportunities"
            Icon="tab_opportunities.svg"
            ContentTemplate="{DataTemplate views:OpportunitiesPage}"
            Route="OpportunitiesPage" />

        <ShellContent
            Title="Profile"
            Icon="tab_profile.svg"
            ContentTemplate="{DataTemplate views:ProfilePage}"
            Route="ProfilePage" />
    </TabBar>

</Shell>

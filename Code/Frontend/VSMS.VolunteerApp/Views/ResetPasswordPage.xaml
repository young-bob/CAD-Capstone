<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.ResetPasswordPage"
             x:DataType="vm:ResetPasswordViewModel"
             Title="Reset Password">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center" MaximumWidthRequest="400">

            <Label Text="Reset Password" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"
                   TextColor="{StaticResource Primary}" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Current Password" FontAttributes="Bold" />
                <Entry Text="{Binding OldPassword}" Placeholder="Enter current password" IsPassword="True" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="New Password" FontAttributes="Bold" />
                <Entry Text="{Binding NewPassword}" Placeholder="Min 8 characters" IsPassword="True" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Confirm New Password" FontAttributes="Bold" />
                <Entry Text="{Binding ConfirmPassword}" Placeholder="Re-enter new password" IsPassword="True" />
            </VerticalStackLayout>

            <Button Text="Reset Password" Command="{Binding ResetPasswordCommand}" IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    CornerRadius="8" HeightRequest="50" FontAttributes="Bold" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

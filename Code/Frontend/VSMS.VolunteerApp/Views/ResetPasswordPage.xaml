<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.ResetPasswordPage"
             x:DataType="vm:ResetPasswordViewModel"
             Title="Reset Password">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center" Padding="24" Spacing="0" MaximumWidthRequest="420">

            <!-- VSMS Branding -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,24">
                <Label Text="♥" FontSize="36" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                <Label Text="VSMS" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Reset Password Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="16">

                    <!-- Header -->
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="Reset Password" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Enter your current and new passwords" Style="{StaticResource MutedText}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <!-- Current Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Current Password" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding OldPassword}" Placeholder="Enter current password" IsPassword="True" />
                    </VerticalStackLayout>

                    <!-- New Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="New Password" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding NewPassword}" Placeholder="Min 8 characters" IsPassword="True" />
                    </VerticalStackLayout>

                    <!-- Confirm New Password -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Confirm New Password" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding ConfirmPassword}" Placeholder="Re-enter new password" IsPassword="True" />
                    </VerticalStackLayout>

                    <!-- Submit -->
                    <Button Text="Update Password"
                            Command="{Binding ResetPasswordCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="48"
                            FontAttributes="Bold"
                            FontSize="16" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             xmlns:models="clr-namespace:VSMS.VolunteerApp.Models"
             xmlns:converters="clr-namespace:VSMS.VolunteerApp.Converters"
             x:Class="VSMS.VolunteerApp.Views.OpportunitiesPage"
             x:DataType="vm:OpportunitiesViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
    </ContentPage.Resources>

    <RefreshView Command="{Binding LoadOpportunitiesCommand}" IsRefreshing="{Binding IsRefreshing}">
        <CollectionView ItemsSource="{Binding Opportunities}" SelectionMode="None">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <Label Text="No opportunities found." HorizontalOptions="Center" />
                    <Button Text="Refresh" Command="{Binding LoadOpportunitiesCommand}" Margin="0,20,0,0" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:OpportunityDetails">
                    <Grid Padding="5">
                        <Border Stroke="LightGray" StrokeThickness="1" StrokeShape="RoundRectangle 10" Padding="10" HeightRequest="120">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="2,2" Radius="5" Opacity="0.1" />
                            </Border.Shadow>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OpportunitiesViewModel}}, Path=GoToDetailsCommand}" 
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Title}" FontSize="18" FontAttributes="Bold" />
                                <Label Text="{Binding VenueLocation.City}" FontSize="14" TextColor="Gray" />
                                <Label Text="{Binding StartTime, StringFormat='{0:MMM dd, HH:mm}'}" FontSize="14" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>
</ContentPage>

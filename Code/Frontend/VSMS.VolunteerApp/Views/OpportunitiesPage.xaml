<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             xmlns:models="clr-namespace:VSMS.VolunteerApp.Models"
             x:Class="VSMS.VolunteerApp.Views.OpportunitiesPage"
             x:DataType="vm:OpportunitiesViewModel"
             Title="Browse Opportunities">

    <RefreshView Command="{Binding LoadOpportunitiesCommand}" IsRefreshing="{Binding IsRefreshing}">
        <ScrollView>
            <VerticalStackLayout Padding="20" Spacing="16">

                <!-- Header -->
                <VerticalStackLayout Spacing="4">
                    <Label Text="Browse Opportunities" Style="{StaticResource PageHeader}" />
                    <Label Text="Find meaningful volunteer work near you." Style="{StaticResource MutedText}" />
                </VerticalStackLayout>

                <!-- Search Bar -->
                <SearchBar Placeholder="Search opportunities..." Text="{Binding SearchText}" />

                <!-- Results -->
                <CollectionView ItemsSource="{Binding FilteredOpportunities}" SelectionMode="None">
                    <CollectionView.EmptyView>
                        <Border Style="{StaticResource CardStyle}" HorizontalOptions="Fill">
                            <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="20">
                                <Label Text="🔍" FontSize="40" HorizontalOptions="Center" />
                                <Label Text="No opportunities found" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                                <Label Text="Try adjusting your search or check back later." Style="{StaticResource MutedText}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OpportunityDetails">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:OpportunitiesViewModel}}, Path=GoToDetailsCommand}"
                                                          CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <VerticalStackLayout Spacing="10">
                                    <!-- Title row with status -->
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Text="{Binding Title}" FontSize="17" FontAttributes="Bold" Grid.Column="0" LineBreakMode="TailTruncation" />
                                        <Border Style="{StaticResource BadgeStyle}" Grid.Column="1" VerticalOptions="Start">
                                            <Label Text="{Binding Visibility}" FontSize="11" TextColor="{StaticResource Primary}" />
                                        </Border>
                                    </Grid>

                                    <!-- Description -->
                                    <Label Text="{Binding Description}" Style="{StaticResource MutedText}" LineBreakMode="TailTruncation" MaxLines="2" />

                                    <!-- Info row -->
                                    <HorizontalStackLayout Spacing="16">
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📅" FontSize="13" />
                                            <Label Text="{Binding StartTime, StringFormat='{0:MMM dd, yyyy}'}" Style="{StaticResource MutedText}" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="📍" FontSize="13" />
                                            <Label Text="{Binding VenueLocation.City}" Style="{StaticResource MutedText}" FontSize="12" />
                                        </HorizontalStackLayout>
                                        <HorizontalStackLayout Spacing="4">
                                            <Label Text="👥" FontSize="13" />
                                            <Label Style="{StaticResource MutedText}" FontSize="12">
                                                <Label.FormattedText>
                                                    <FormattedString>
                                                        <Span Text="{Binding RegisteredCount}" />
                                                        <Span Text="/" />
                                                        <Span Text="{Binding MaxVolunteers}" />
                                                    </FormattedString>
                                                </Label.FormattedText>
                                            </Label>
                                        </HorizontalStackLayout>
                                    </HorizontalStackLayout>

                                    <!-- View Details -->
                                    <Label Text="View Details ›" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="13" HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

            </VerticalStackLayout>
        </ScrollView>
    </RefreshView>
</ContentPage>

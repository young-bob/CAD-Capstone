<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             Title="Register"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout VerticalOptions="Center" Padding="24" Spacing="0" MaximumWidthRequest="480">

            <!-- VSMS Branding -->
            <VerticalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,0,0,20">
                <Label Text="♥" FontSize="36" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
                <Label Text="VSMS" FontSize="24" FontAttributes="Bold" TextColor="{StaticResource Primary}" HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- Register Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">

                    <!-- Header -->
                    <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                        <Label Text="Create your account" FontSize="22" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        <Label Text="Start making a difference today" Style="{StaticResource MutedText}" HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>

                    <!-- Name + Email row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="Full Name" FontAttributes="Bold" FontSize="13" />
                            <Entry Text="{Binding Name}" Placeholder="John Doe" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="Email" FontAttributes="Bold" FontSize="13" />
                            <Entry Text="{Binding Email}" Placeholder="you@example.com" Keyboard="Email" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Password + Phone row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="Password" FontAttributes="Bold" FontSize="13" />
                            <Entry Text="{Binding Password}" Placeholder="Min 8 characters" IsPassword="True" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="Phone Number" FontAttributes="Bold" FontSize="13" />
                            <Entry Text="{Binding PhoneNumber}" Placeholder="555-0123" Keyboard="Telephone" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Bio -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Bio" FontAttributes="Bold" FontSize="13" />
                        <Editor Text="{Binding Bio}" Placeholder="Tell us about yourself..." HeightRequest="70" />
                    </VerticalStackLayout>

                    <!-- Location Section -->
                    <Label Text="Location" FontSize="16" FontAttributes="Bold" Margin="0,4,0,0" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Address" FontSize="13" />
                        <Entry Text="{Binding Address}" Placeholder="123 Main St" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="City" FontSize="13" />
                            <Entry Text="{Binding City}" Placeholder="City" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="Province" FontSize="13" />
                            <Entry Text="{Binding Province}" Placeholder="ON" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Postal Code" FontSize="13" />
                        <Entry Text="{Binding PostalCode}" Placeholder="N2L 3G1" />
                    </VerticalStackLayout>

                    <!-- Register Button -->
                    <Button Text="Create Account"
                            Command="{Binding RegisterCommand}"
                            IsEnabled="{Binding IsNotBusy}"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="White"
                            CornerRadius="8"
                            HeightRequest="48"
                            FontAttributes="Bold"
                            FontSize="16"
                            Margin="0,6,0,0" />

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

                    <!-- Login Link -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="4" Margin="0,4,0,8">
                        <Label Text="Already have an account?" Style="{StaticResource MutedText}" />
                        <Label Text="Sign in" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="14">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding GoToLoginCommand}" />
                            </Label.GestureRecognizers>
                        </Label>
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

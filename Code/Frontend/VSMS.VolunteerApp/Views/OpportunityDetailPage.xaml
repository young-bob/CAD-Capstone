<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             xmlns:models="clr-namespace:VSMS.VolunteerApp.Models"
             xmlns:converters="clr-namespace:VSMS.VolunteerApp.Converters"
             x:Class="VSMS.VolunteerApp.Views.OpportunityDetailPage"
             x:DataType="vm:OpportunityDetailViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Title Section -->
            <Border StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    Padding="24"
                    BackgroundColor="#0D9488">
                <Border.Shadow>
                    <Shadow Brush="#0D9488" Offset="0,4" Radius="16" Opacity="0.3" />
                </Border.Shadow>
                <Label Text="{Binding Opportunity.Title}"
                       FontSize="22" FontAttributes="Bold"
                       TextColor="White" />
            </Border>

            <!-- Description Card -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                    StrokeThickness="1"
                    Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Description" FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}" />
                    <Label Text="{Binding Opportunity.Description}" FontSize="15"
                           LineBreakMode="WordWrap" />
                </VerticalStackLayout>
            </Border>

            <!-- Location & Time -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                        StrokeThickness="1"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📍 Location" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}" />
                        <Label Text="{Binding Opportunity.VenueLocation.Address}"
                               FontSize="14" LineBreakMode="WordWrap" />
                        <Label Text="{Binding Opportunity.VenueLocation.City}"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}" />
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                        StrokeThickness="1"
                        Padding="16"
                        BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="🕐 Schedule" FontSize="13" FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}" />
                        <Label Text="{Binding Opportunity.StartTime, StringFormat='{0:MMM dd}'}"
                               FontSize="14" />
                        <HorizontalStackLayout Spacing="4">
                            <Label Text="{Binding Opportunity.StartTime, StringFormat='{0:HH:mm}'}"
                                   FontSize="13" TextColor="#0D9488" FontAttributes="Bold" />
                            <Label Text="–" FontSize="13" />
                            <Label Text="{Binding Opportunity.EndTime, StringFormat='{0:HH:mm}'}"
                                   FontSize="13" TextColor="#0D9488" FontAttributes="Bold" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Apply Button -->
            <Button Text="Apply Now"
                    Command="{Binding ApplyCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="#0D9488"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="12"
                    HeightRequest="50"
                    Margin="0,10,0,0"
                    HorizontalOptions="Fill" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#0D9488" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

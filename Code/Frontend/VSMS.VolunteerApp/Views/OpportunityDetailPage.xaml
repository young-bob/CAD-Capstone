<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             xmlns:models="clr-namespace:VSMS.VolunteerApp.Models"
             xmlns:converters="clr-namespace:VSMS.VolunteerApp.Converters"
             x:Class="VSMS.VolunteerApp.Views.OpportunityDetailPage"
             x:DataType="vm:OpportunityDetailViewModel"
             Title="{Binding Title}">

    <ContentPage.Resources>
        <converters:IntToBoolConverter x:Key="IntToBoolConverter" />
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="{Binding Opportunity.Title}" FontSize="24" FontAttributes="Bold" />
            
            <Label Text="{Binding Opportunity.Description}" FontSize="16" />
            
            <BoxView HeightRequest="1" Color="Gray" />
            
            <Label Text="Location" FontAttributes="Bold" />
            <Label Text="{Binding Opportunity.VenueLocation.Address}" />
            <Label Text="{Binding Opportunity.VenueLocation.City}" />
            
            <Label Text="Time" FontAttributes="Bold" Margin="0,10,0,0" />
            <HorizontalStackLayout Spacing="10">
                <Label Text="{Binding Opportunity.StartTime, StringFormat='{0:MMM dd, HH:mm}'}" />
                <Label Text="-" />
                <Label Text="{Binding Opportunity.EndTime, StringFormat='{0:HH:mm}'}" />
            </HorizontalStackLayout>
            
            <!-- Skills section commented out until model supports it
            <Label Text="Skills Required" FontAttributes="Bold" Margin="0,10,0,0" IsVisible="{Binding Opportunity.RequiredSkills.Count, Converter={StaticResource IntToBoolConverter}}" />
            
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding Opportunity.RequiredSkills}" Spacing="5">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                         <Label Text="{Binding .}" TextColor="{StaticResource Primary}" />
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
            -->

            <Button Text="Apply Now" 
                    Command="{Binding ApplyCommand}" 
                    IsEnabled="{Binding IsNotBusy}"
                    Margin="0,20,0,0" />
            
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.OpportunityDetailPage"
             x:DataType="vm:OpportunityDetailViewModel"
             Title="Opportunity Details">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Title + Status -->
            <Grid ColumnDefinitions="*,Auto">
                <Label Text="{Binding Opportunity.Title}" Style="{StaticResource PageHeader}" Grid.Column="0" />
                <Border Style="{StaticResource BadgeStyle}" Grid.Column="1" VerticalOptions="Start">
                    <Label Text="{Binding Opportunity.Visibility}" FontSize="12" TextColor="{StaticResource Primary}" />
                </Border>
            </Grid>

            <!-- Info Cards Row -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                <!-- Dates -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="0">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📅" FontSize="20" />
                        <Label Text="Dates" Style="{StaticResource MutedText}" FontSize="11" />
                        <Label Text="{Binding Opportunity.StartTime, StringFormat='{0:MMM dd}'}" FontSize="13" FontAttributes="Bold" />
                        <Label Text="{Binding Opportunity.EndTime, StringFormat='to {0:MMM dd}'}" Style="{StaticResource MutedText}" FontSize="11" />
                    </VerticalStackLayout>
                </Border>

                <!-- Volunteers -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="1">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="👥" FontSize="20" />
                        <Label Text="Volunteers" Style="{StaticResource MutedText}" FontSize="11" />
                        <Label FontSize="13" FontAttributes="Bold">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Opportunity.RegisteredCount}" />
                                    <Span Text=" / " />
                                    <Span Text="{Binding Opportunity.MaxVolunteers}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </VerticalStackLayout>
                </Border>

                <!-- Location -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Column="2">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="📍" FontSize="20" />
                        <Label Text="Location" Style="{StaticResource MutedText}" FontSize="11" />
                        <Label Text="{Binding Opportunity.VenueLocation.City}" FontSize="13" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                        <Label Text="{Binding Opportunity.VenueLocation.Province}" Style="{StaticResource MutedText}" FontSize="11" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Description Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Description" Style="{StaticResource SectionTitle}" />
                    <Label Text="{Binding Opportunity.Description}" Style="{StaticResource MutedText}" FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <!-- Location Details Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="8">
                    <Label Text="Venue Details" Style="{StaticResource SectionTitle}" />
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="📍" FontSize="14" />
                        <Label Text="{Binding Opportunity.VenueLocation.Address}" FontSize="14" />
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="🏙" FontSize="14" />
                        <Label FontSize="14">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Opportunity.VenueLocation.City}" />
                                    <Span Text=", " />
                                    <Span Text="{Binding Opportunity.VenueLocation.Province}" />
                                    <Span Text=" " />
                                    <Span Text="{Binding Opportunity.VenueLocation.PostalCode}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>
                    <HorizontalStackLayout Spacing="6">
                        <Label Text="⏰" FontSize="14" />
                        <Label FontSize="14">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Opportunity.StartTime, StringFormat='{0:MMM dd, HH:mm}'}" />
                                    <Span Text=" – " />
                                    <Span Text="{Binding Opportunity.EndTime, StringFormat='{0:HH:mm}'}" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Sign Up Button -->
            <Button Text="Sign Up for this Opportunity"
                    Command="{Binding ApplyCommand}"
                    IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="48"
                    FontAttributes="Bold"
                    FontSize="16" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.ManageShiftsPage"
             x:DataType="vm:ManageShiftsViewModel"
             Title="Create Shift">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15" VerticalOptions="Center">
            <Label Text="Create a Shift" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Opportunity" FontAttributes="Bold" />
                <Picker Title="Select Opportunity" ItemsSource="{Binding Opportunities}"
                        SelectedItem="{Binding SelectedOpportunity}"
                        ItemDisplayBinding="{Binding Title}" />
            </VerticalStackLayout>

            <Button Text="Create Shift" Command="{Binding CreateShiftCommand}" IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="8" HeightRequest="50" />
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ActionText}" Command="{Binding ToggleEditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView HorizontalScrollBarVisibility="Never">
        <VerticalStackLayout Spacing="16" Padding="20">

            <!-- Profile Header -->
            <Border StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    Padding="24"
                    BackgroundColor="#0D9488">
                <Border.Shadow>
                    <Shadow Brush="#0D9488" Offset="0,4" Radius="16" Opacity="0.3" />
                </Border.Shadow>
                <HorizontalStackLayout Spacing="16">
                    <!-- Avatar -->
                    <Border StrokeShape="RoundRectangle 30"
                            StrokeThickness="0"
                            WidthRequest="60" HeightRequest="60"
                            BackgroundColor="#B2DFDB"
                            HorizontalOptions="Start" VerticalOptions="Center">
                        <Label Text="👤" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding Profile.Email}" FontSize="16" FontAttributes="Bold" TextColor="White" />
                        <Label Text="{Binding Profile.TotalHours, StringFormat='{0:F1} hours volunteered'}"
                               FontSize="13" TextColor="#B2DFDB" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- Contact Info Card -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                    StrokeThickness="1"
                    Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Contact Information" FontSize="15" FontAttributes="Bold"
                           TextColor="#0D9488" />

                    <VerticalStackLayout Spacing="4">
                        <Label Text="📧  Email" FontSize="12"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}" />
                        <Entry Text="{Binding Profile.Email}" IsReadOnly="True" FontSize="14" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="4">
                        <Label Text="📱  Phone" FontSize="12"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}" />
                        <Entry Text="{Binding Profile.PhoneNumber}"
                               IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                               FontSize="14" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Bio Card -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                    StrokeThickness="1"
                    Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="📝  Bio" FontSize="15" FontAttributes="Bold"
                           TextColor="#0D9488" />
                    <Editor Text="{Binding Profile.Bio}" HeightRequest="100"
                            IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}"
                            FontSize="14" />
                </VerticalStackLayout>
            </Border>

            <!-- Skills Card -->
            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                    StrokeThickness="1"
                    Padding="18"
                    BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="🎯  Skills" FontSize="15" FontAttributes="Bold"
                           TextColor="#0D9488" />
                    <CollectionView ItemsSource="{Binding Profile.Skills}" HeightRequest="80" HorizontalScrollBarVisibility="Never">
                        <CollectionView.ItemsLayout>
                            <LinearItemsLayout Orientation="Horizontal" ItemSpacing="8" />
                        </CollectionView.ItemsLayout>
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Border StrokeShape="RoundRectangle 10"
                                        StrokeThickness="0"
                                        Padding="12,6"
                                        BackgroundColor="#E6FFFA"
                                        HeightRequest="34"
                                        VerticalOptions="Start">
                                    <Label Text="{Binding .}" FontSize="13" TextColor="#0D9488" />
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#0D9488" HorizontalOptions="Center" />

            <!-- Logout Button -->
            <Button Text="Sign Out"
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="#E53E3E"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12"
                    HeightRequest="48"
                    Margin="0,10,0,0"
                    HorizontalOptions="Fill" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

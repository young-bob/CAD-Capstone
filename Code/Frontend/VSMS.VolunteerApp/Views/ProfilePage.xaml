<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="My Profile">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ActionText}" Command="{Binding ToggleEditCommand}" />
        <ToolbarItem Text="Cancel" Command="{Binding CancelEditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="My Profile" Style="{StaticResource PageHeader}" />
                <Label Text="Manage your volunteer profile" Style="{StaticResource MutedText}" />
            </VerticalStackLayout>

            <!-- Total Hours Stat Card -->
            <Border Style="{StaticResource StatCardStyle}">
                <HorizontalStackLayout Spacing="16">
                    <Label Text="⏱" FontSize="32" VerticalOptions="Center" />
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label Text="Total Volunteer Hours" Style="{StaticResource MutedText}" FontSize="12" />
                        <Label Text="{Binding Profile.TotalHours, StringFormat='{0:F1}'}" FontSize="32" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- Personal Info Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Personal Information" Style="{StaticResource SectionTitle}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Name" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditName}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Email" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding Profile.Email}" IsReadOnly="True" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Phone" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditPhone}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Bio" FontAttributes="Bold" FontSize="13" />
                        <Editor Text="{Binding EditBio}" HeightRequest="80"
                                IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Location Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Location" Style="{StaticResource SectionTitle}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Address" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditAddress}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6" Grid.Column="0">
                            <Label Text="City" FontAttributes="Bold" FontSize="13" />
                            <Entry Text="{Binding EditCity}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Spacing="6" Grid.Column="1">
                            <Label Text="Province" FontAttributes="Bold" FontSize="13" />
                            <Entry Text="{Binding EditProvince}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                        </VerticalStackLayout>
                    </Grid>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Postal Code" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditPostalCode}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

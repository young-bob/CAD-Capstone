<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.ProfilePage"
             x:DataType="vm:ProfileViewModel"
             Title="Profile">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ActionText}" Command="{Binding ToggleEditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="20">
            <!-- Name -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Name" FontAttributes="Bold" />
                <Entry Text="{Binding EditName}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>

            <!-- Email (read-only) -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Email" FontAttributes="Bold" />
                <Entry Text="{Binding Profile.Email}" IsReadOnly="True" />
            </VerticalStackLayout>

            <!-- Phone -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Phone" FontAttributes="Bold" />
                <Entry Text="{Binding EditPhone}" IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>

            <!-- Bio -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Bio" FontAttributes="Bold" />
                <Editor Text="{Binding EditBio}" HeightRequest="100"
                        IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
            </VerticalStackLayout>
            
            <!-- Total Hours -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Total Hours" FontAttributes="Bold" />
                <Label Text="{Binding Profile.TotalHours, StringFormat='{0:F1}'}" FontSize="18" />
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

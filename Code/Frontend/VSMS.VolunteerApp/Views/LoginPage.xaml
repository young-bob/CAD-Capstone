<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.LoginPage"
             Title="Login Details"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30,60,30,30" VerticalOptions="Center">

            <!-- App Logo -->
            <Image
                Source="vsms_logo.png"
                SemanticProperties.Description="VSMS Logo"
                HeightRequest="120"
                WidthRequest="120"
                Aspect="AspectFit"
                HorizontalOptions="Center" />

            <!-- App Title -->
            <Label
                Text="VSMS"
                FontSize="36"
                FontAttributes="Bold"
                TextColor="#0D9488"
                HorizontalOptions="Center" />

            <Label
                Text="Volunteer Service Management"
                FontSize="14"
                HorizontalOptions="Center"
                TextColor="{AppThemeBinding Light=Gray, Dark=#A0AEC0}" />

            <Label
                Text="Log in to explore volunteer opportunities"
                FontSize="16"
                HorizontalOptions="Center"
                Margin="0,10,0,0"
                TextColor="{AppThemeBinding Light=#4A5568, Dark=#CBD5E0}" />

            <!-- Login Form Card -->
            <Border StrokeShape="RoundRectangle 16"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                    StrokeThickness="1"
                    Padding="20"
                    Margin="0,10,0,0"
                    BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.08" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="15">
                    <Label Text="Email" FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4A5568, Dark=#A0AEC0}" />
                    <Entry
                        Placeholder="you@example.com"
                        Text="{Binding Email}"
                        Keyboard="Email"
                        ClearButtonVisibility="WhileEditing" />

                    <Label Text="Password" FontSize="13" FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#4A5568, Dark=#A0AEC0}" />
                    <Entry
                        Placeholder="••••••••"
                        Text="{Binding Password}"
                        IsPassword="True"
                        ClearButtonVisibility="WhileEditing" />

                    <Button
                        Text="Sign In"
                        Command="{Binding LoginCommand}"
                        BackgroundColor="#0D9488"
                        TextColor="White"
                        FontAttributes="Bold"
                        FontSize="16"
                        CornerRadius="12"
                        HeightRequest="50"
                        Margin="0,5,0,0"
                        HorizontalOptions="Fill" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator
                IsRunning="{Binding IsBusy}"
                IsVisible="{Binding IsBusy}"
                Color="#0D9488"
                HorizontalOptions="Center" />

            <Button
                Text="Don't have an account? Register"
                Command="{Binding GoToRegisterCommand}"
                BackgroundColor="Transparent"
                TextColor="#0D9488"
                FontSize="14"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.VerifyCredentialsPage"
             x:DataType="vm:VerifyCredentialsViewModel"
             Title="Verify Credentials">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Label Text="Verify a Volunteer's Credential" FontSize="20" FontAttributes="Bold" />

            <VerticalStackLayout Spacing="5">
                <Label Text="Volunteer ID" FontAttributes="Bold" />
                <Entry Text="{Binding VolunteerIdText}" Placeholder="Enter volunteer UUID" />
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="5">
                <Label Text="Credential ID" FontAttributes="Bold" />
                <Entry Text="{Binding CredentialIdText}" Placeholder="Enter credential UUID" />
            </VerticalStackLayout>

            <Button Text="Verify" Command="{Binding VerifyCommand}" IsEnabled="{Binding IsNotBusy}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White" CornerRadius="8" HeightRequest="50" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

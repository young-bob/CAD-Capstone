<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             xmlns:models="clr-namespace:VSMS.VolunteerApp.Models"
             x:Class="VSMS.VolunteerApp.Views.CertificatesPage"
             x:DataType="vm:CertificatesViewModel"
             Title="Certificates">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header -->
            <VerticalStackLayout Spacing="4">
                <Label Text="My Certificates" Style="{StaticResource PageHeader}" />
                <Label Text="View and download your earned certificates" Style="{StaticResource MutedText}" />
            </VerticalStackLayout>

            <!-- Certificates List -->
            <CollectionView ItemsSource="{Binding Certificates}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource CardStyle}" HorizontalOptions="Fill">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="20">
                            <Label Text="🏆" FontSize="40" HorizontalOptions="Center" />
                            <Label Text="No certificates yet" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Complete volunteering opportunities to earn certificates!" Style="{StaticResource MutedText}" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:CertificateDetails">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CertificatesViewModel}}, Path=ViewDetailCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="14">
                                <!-- Award Icon -->
                                <Border Grid.Column="0" BackgroundColor="{StaticResource PrimaryLight}"
                                        StrokeShape="RoundRectangle 8" Stroke="Transparent"
                                        HeightRequest="44" WidthRequest="44" Padding="0">
                                    <Label Text="🏆" FontSize="22" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>

                                <!-- Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="4" VerticalOptions="Center">
                                    <Label Text="{Binding VolunteerId}" FontSize="14" FontAttributes="Bold" LineBreakMode="TailTruncation" />
                                    <HorizontalStackLayout Spacing="8">
                                        <Label Text="{Binding IssuedAt, StringFormat='{0:MMM dd, yyyy}'}" Style="{StaticResource MutedText}" FontSize="12" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>

                                <!-- Download -->
                                <Button Grid.Column="2" Text="📥" FontSize="18"
                                        BackgroundColor="Transparent"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CertificatesViewModel}}, Path=DownloadCommand}"
                                        CommandParameter="{Binding .}"
                                        WidthRequest="44" HeightRequest="44" Padding="0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

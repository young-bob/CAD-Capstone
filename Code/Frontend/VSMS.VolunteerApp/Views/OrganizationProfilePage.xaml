<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.OrganizationProfilePage"
             x:DataType="vm:OrganizationProfileViewModel"
             Title="Organization">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="{Binding ActionText}" Command="{Binding ToggleEditCommand}" />
        <ToolbarItem Text="Cancel" Command="{Binding CancelEditCommand}" />
    </ContentPage.ToolbarItems>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">

            <!-- Header Card -->
            <Border Style="{StaticResource CardStyle}">
                <HorizontalStackLayout Spacing="16">
                    <Border BackgroundColor="{StaticResource PrimaryLight}" StrokeShape="RoundRectangle 12"
                            Stroke="Transparent" HeightRequest="64" WidthRequest="64" Padding="0">
                        <Label Text="🏢" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="4" VerticalOptions="Center">
                        <Label Text="{Binding Organization.Name}" FontSize="20" FontAttributes="Bold" />
                        <Border Style="{StaticResource BadgeStyle}">
                            <Label Text="{Binding VerificationText}" FontSize="11" TextColor="{Binding VerificationColor}" />
                        </Border>
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>

            <!-- Details Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Organization Details" Style="{StaticResource SectionTitle}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Description" FontAttributes="Bold" FontSize="13" />
                        <Editor Text="{Binding EditDescription}" HeightRequest="80"
                                IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Website" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditWebsite}" Placeholder="https://..."
                               IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Logo URL" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditLogoUrl}" Placeholder="Logo image URL"
                               IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <!-- Calendar & Location Card -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="14">
                    <Label Text="Integration" Style="{StaticResource SectionTitle}" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Calendar Sync URL" FontAttributes="Bold" FontSize="13" />
                        <Entry Text="{Binding EditCalendarSyncUrl}" Placeholder="Calendar feed URL"
                               IsReadOnly="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}" />
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Location" FontAttributes="Bold" FontSize="13" />
                        <HorizontalStackLayout Spacing="8">
                            <Label Text="📍" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding Organization.Location.City}" FontSize="14" VerticalOptions="Center" />
                            <Label Text="{Binding Organization.Location.Province}" FontSize="14" Style="{StaticResource MutedText}" VerticalOptions="Center" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

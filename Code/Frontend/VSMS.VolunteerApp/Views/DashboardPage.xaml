<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             xmlns:models="clr-namespace:VSMS.VolunteerApp.Models"
             x:Class="VSMS.VolunteerApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Welcome Header -->
            <VerticalStackLayout Spacing="4">
                <Label Style="{StaticResource PageHeader}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Welcome back, " />
                            <Span Text="{Binding VolunteerName}" />
                            <Span Text="!" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label Text="Here's an overview of your activity." Style="{StaticResource MutedText}" />
            </VerticalStackLayout>

            <!-- Stat Cards Grid (2x2) -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">

                <!-- Total Hours -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Row="0" Grid.Column="0">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="⏱" FontSize="24" />
                        <Label Text="Total Hours" Style="{StaticResource MutedText}" FontSize="12" />
                        <Label Text="{Binding TotalHours, StringFormat='{0:F1}'}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Opportunities -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Row="0" Grid.Column="1">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📋" FontSize="24" />
                        <Label Text="Opportunities" Style="{StaticResource MutedText}" FontSize="12" />
                        <Label Text="{Binding OpportunityCount}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Upcoming -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Row="1" Grid.Column="0">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="📅" FontSize="24" />
                        <Label Text="Upcoming" Style="{StaticResource MutedText}" FontSize="12" />
                        <Label Text="{Binding UpcomingCount}" FontSize="28" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

                <!-- Role -->
                <Border Style="{StaticResource StatCardStyle}" Grid.Row="1" Grid.Column="1">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="👤" FontSize="24" />
                        <Label Text="Your Role" Style="{StaticResource MutedText}" FontSize="12" />
                        <Label Text="{Binding UserRole}" FontSize="18" FontAttributes="Bold" TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Upcoming Opportunities -->
            <VerticalStackLayout Spacing="8">
                <Label Text="Upcoming Opportunities" Style="{StaticResource SectionTitle}" />
                <Label Text="Your next volunteering activities" Style="{StaticResource MutedText}" />
            </VerticalStackLayout>

            <CollectionView ItemsSource="{Binding UpcomingOpportunities}" SelectionMode="None">
                <CollectionView.EmptyView>
                    <Border Style="{StaticResource CardStyle}" HorizontalOptions="Fill">
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center" Padding="20">
                            <Label Text="📋" FontSize="40" HorizontalOptions="Center" />
                            <Label Text="No upcoming opportunities" FontSize="16" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Browse opportunities to get started!" Style="{StaticResource MutedText}" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Border>
                </CollectionView.EmptyView>
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:OpportunityDetails">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="6">
                                <!-- Title -->
                                <Label Text="{Binding Title}" FontSize="16" FontAttributes="Bold" Grid.Row="0" Grid.Column="0" />

                                <!-- Date badge -->
                                <Border Style="{StaticResource BadgeStyle}" Grid.Row="0" Grid.Column="1" VerticalOptions="Start">
                                    <Label Text="{Binding StartTime, StringFormat='{0:MMM dd}'}" FontSize="11" TextColor="{StaticResource Primary}" />
                                </Border>

                                <!-- Description -->
                                <Label Text="{Binding Description}" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                       Style="{StaticResource MutedText}" LineBreakMode="TailTruncation" MaxLines="2" />

                                <!-- Location -->
                                <HorizontalStackLayout Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Spacing="12">
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="📍" FontSize="12" />
                                        <Label Text="{Binding VenueLocation.City}" Style="{StaticResource MutedText}" FontSize="12" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="4">
                                        <Label Text="👥" FontSize="12" />
                                        <Label Style="{StaticResource MutedText}" FontSize="12">
                                            <Label.FormattedText>
                                                <FormattedString>
                                                    <Span Text="{Binding RegisteredCount}" />
                                                    <Span Text="/" />
                                                    <Span Text="{Binding MaxVolunteers}" />
                                                </FormattedString>
                                            </Label.FormattedText>
                                        </Label>
                                    </HorizontalStackLayout>
                                </HorizontalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" HorizontalOptions="Center" Color="{StaticResource Primary}" />

            <!-- Logout Button -->
            <Button Text="Log out" Command="{Binding LogoutCommand}" Style="{StaticResource OutlineButton}" Margin="0,10,0,20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VSMS.VolunteerApp.ViewModels"
             x:Class="VSMS.VolunteerApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <!-- Welcome Header -->
            <Border StrokeShape="RoundRectangle 16"
                    StrokeThickness="0"
                    Padding="24"
                    BackgroundColor="#0D9488">
                <Border.Shadow>
                    <Shadow Brush="#0D9488" Offset="0,4" Radius="16" Opacity="0.3" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="8">
                    <Label Text="{Binding VolunteerName, StringFormat='Welcome back, {0}!'}"
                           FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="Here's your volunteering summary"
                           FontSize="14" TextColor="#B2DFDB" />
                </VerticalStackLayout>
            </Border>

            <!-- Stats Cards Row -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <!-- Total Hours Card -->
                <Border Grid.Column="0"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                        StrokeThickness="1"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="⏱️" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="{Binding TotalHours, StringFormat='{0:F1}'}"
                               FontSize="32" FontAttributes="Bold"
                               TextColor="#0D9488"
                               HorizontalOptions="Center" />
                        <Label Text="Total Hours" FontSize="12"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>

                <!-- Status Card -->
                <Border Grid.Column="1"
                        StrokeShape="RoundRectangle 14"
                        Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                        StrokeThickness="1"
                        Padding="20"
                        BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="✅" FontSize="28" HorizontalOptions="Center" />
                        <Label Text="Active"
                               FontSize="20" FontAttributes="Bold"
                               TextColor="#10B981"
                               HorizontalOptions="Center" />
                        <Label Text="Status" FontSize="12"
                               TextColor="{AppThemeBinding Light=#718096, Dark=#A0AEC0}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <Label Text="Quick Actions" FontSize="18" FontAttributes="Bold" Margin="0,5,0,0" />

            <Border StrokeShape="RoundRectangle 14"
                    Stroke="{AppThemeBinding Light=#E2E8F0, Dark=#4A5568}"
                    StrokeThickness="1"
                    Padding="16"
                    BackgroundColor="{AppThemeBinding Light=#F7FAFC, Dark=#2D3748}">
                <VerticalStackLayout Spacing="12">
                    <Label Text="💡  Browse available volunteer opportunities in the Opportunities tab."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#4A5568, Dark=#CBD5E0}" />
                    <Label Text="👤  Update your profile and skills in the Profile tab."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#4A5568, Dark=#CBD5E0}" />
                </VerticalStackLayout>
            </Border>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#0D9488" HorizontalOptions="Center" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

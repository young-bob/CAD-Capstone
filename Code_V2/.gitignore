# .gitignore for VSMS (Full Stack .NET + React Native)

# ====================
# OS Specific
# ====================
.DS_Store
.AppleDouble
.LSOverride
*.sh

# Windows image databases
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Windows Installer logs
*.cab
*.msi
*.msix
*.msm
*.msp

# Others
desktop.ini
[Dd]esktop.ini
$RECYCLE.BIN/
*.lnk
*.swp
*~

# ====================
# .NET / Visual Studio
# ====================
bin/
obj/
[Ee]xecution/
[Tt]est[Rr]esults/
*.user
*.suo
*.userosscache
*.sln.docstates

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# Rider
.idea/
*.sln.iml

# Visual Studio Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ====================
# Node.js / React Native (Mobile)
# ====================
node_modules/
dist/
build/
.expo/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
ios/Pods/
ios/build/
android/app/build/
android/.gradle/
android/app/*.iml
android/*.iml

# ====================
# Docker / Podman / Local Data
# ====================
# Local persistence data
data/
# Environment files
.env
.env.local
.env.*.local
!.env.example
# Local dev secrets — never commit these
appsettings.Development.json
appsettings.Local.json
appsettings.json

# ====================
# Other
# ====================
*.log
tmp/
temp/

# ============================================================
# VSMS Environment Variables
# Copy to .env on each server, update values accordingly
# ============================================================

# ---- All Servers ----
POSTGRES_PASSWORD=Change-Me!!

# ---- API Servers ----
DB_HOST=x.x.x.x
JWT_SECRET=Change-Me-with-min-33-characters!!

# ---- Orleans Clustering ----
ADVERTISED_IP=x.x.x.x

# ---- MinIO File Storage ----
MINIO_HOST=x.x.x.x
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=Change-Me!!

# ---- AI Inference (AWS API Gateway / Bedrock Proxy) ----
AI_PROVIDER=BedrockDirect
AI_REGION=ca-central-1
# Optional fallback (used only when AI_PROVIDER=AwsApi):
AI_ENDPOINT=https://your-ai-gateway.example.com/v1/chat/completions
AI_MODEL=us.amazon.nova-2-lite-v1:0
# Authorization (Bearer) or x-api-key depending on your gateway.
AI_API_KEY_HEADER=Authorization
AI_API_KEY=Change-Me
AI_TIMEOUT_SECONDS=60
AI_DEFAULT_TEMPERATURE=0.2
AI_DEFAULT_MAX_TOKENS=900

# ============================================================
# VSMS Environment Variables
# Copy to .env on each server, update values accordingly
# ============================================================

# ---- All Servers ----
POSTGRES_PASSWORD=vsms_secret_2026

# ---- API Servers (10.20.30.2, 10.20.30.3) ----
DB_HOST=10.20.30.4
JWT_SECRET=VSMS-Production-Secret-Key-Change-Me-Min32Chars!!

# ---- Orleans Clustering ----
# IMPORTANT: Set this to the current server's own IP!
# On 10.20.30.2: ADVERTISED_IP=10.20.30.2
# On 10.20.30.3: ADVERTISED_IP=10.20.30.3
ADVERTISED_IP=10.20.30.2

# ---- MinIO File Storage (DB Server 10.20.30.4) ----
MINIO_HOST=10.20.30.4
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
